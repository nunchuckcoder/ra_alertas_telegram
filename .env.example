# ─────────────────────────────────────────────────────────────
#  Configuração do bot — copia este ficheiro para .env e preenche
#  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# TELEGRAM
# Token do bot (obtém-o no @BotFather)
BOT_TOKEN=

# CONFIGURAÇÕES DOS SISMOS (comando /sismos)
SEISMIC_LIMIT=10
SEISMIC_START=2025-01-01
# SEISMIC_END=2025-12-31   # opcional — comenta para não usar data final
SEISMIC_FORMAT=json
SEISMIC_MINMAG=2

# CANAIS PARA ALERTAS DE SISMOS
# IDs de canais/grupos separados por vírgula. Ex.: -1000000000000,-4444444444,5555555555
ALERTA_SISMOS_CHANNEL_IDS=
# Magnitude mínima para o alerta de sismos graves
MIN_MAGNITUDE_ALERTA=6
# Intervalo entre verificações, em segundos (1800 = 30 minutos)
INTERVALO_VERIFICACAO=600

# ENDPOINTS DAS APIS (públicas — não requerem chave)
IPMA_API=https://api.ipma.pt/public-data/forecast/aggregate/
FOGOS_API=https://api-dev.fogos.pt/v1/active/
SISMOS_API=https://www.seismicportal.eu/fdsnws/event/1/query
